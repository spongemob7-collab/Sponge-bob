{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User body metrics and fitness goals",
      "type": "object",
      "properties": {
        "age": { "type": "integer" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "weight": { "type": "number", "description": "Weight in kg" },
        "height": { "type": "number", "description": "Height in cm" },
        "fitnessGoal": { "type": "string", "enum": ["lose weight", "maintain", "gain muscle"] },
        "targetCalories": { "type": "number" },
        "dailyWaterTarget": { "type": "number", "description": "Target in ml" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["age", "gender", "weight", "height", "fitnessGoal"]
    },
    "Meal": {
      "title": "Meal Entry",
      "description": "Logged food consumption",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "category": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "description": "YYYY-MM-DD" }
      },
      "required": ["name", "calories", "category", "date"]
    },
    "Workout": {
      "title": "Workout Entry",
      "description": "Logged physical activity",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "caloriesBurned": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "description": "YYYY-MM-DD" }
      },
      "required": ["type", "duration", "caloriesBurned", "date"]
    },
    "DailyStats": {
      "title": "Daily Tracking Stats",
      "description": "Steps and water intake per day",
      "type": "object",
      "properties": {
        "steps": { "type": "integer" },
        "waterIntake": { "type": "number", "description": "Amount in ml" },
        "date": { "type": "string", "description": "YYYY-MM-DD" }
      },
      "required": ["date"]
    },
    "SavedRecipe": {
      "title": "AI Generated Recipe",
      "description": "Recipe generated by Gemini AI",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "array", "items": { "type": "string" } },
        "calories": { "type": "number" },
        "prepTime": { "type": "string" },
        "inputIngredients": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ingredients", "instructions", "calories"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Core user profile data"
    },
    "users/{userId}/meals/{mealId}": {
      "schema": "Meal",
      "description": "Individual meal logs"
    },
    "users/{userId}/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Individual workout logs"
    },
    "users/{userId}/dailyStats/{dateId}": {
      "schema": "DailyStats",
      "description": "Daily metrics for steps and water"
    },
    "users/{userId}/savedRecipes/{recipeId}": {
      "schema": "SavedRecipe",
      "description": "User saved AI recipes"
    }
  }
}
